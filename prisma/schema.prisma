model products {
  id                  String                @id @db.VarChar(50)
  category_slug       String                @db.VarChar(100)
  name                String                @db.VarChar(255)
  origin              String?               @db.VarChar(255)
  description         String?               @db.Text
  tasting_notes       String?               @db.VarChar(255)
  roast_profile       String?               @db.VarChar(100)
  acidity_level       Int?                  @default(1)
  roast_level         Int?                  @default(1)
  cogs                Int?                  @default(0)
  base_price          Int?                  @default(0)
  stock               Int?                  @default(0)
  
  // 👇 UPDATED: Changed to LongText to safely hold massive Base64 image strings
  main_image          String?               @db.LongText
  
  // 👇 NEW: Store the 4 gallery images directly as a simple JSON array!
  gallery             Json?                 
  
  roast_log           String?               @db.Text
  created_at          DateTime              @default(now()) @db.Timestamp(0)
  updated_at          DateTime              @default(now()) @db.Timestamp(0)
  discount_price      Int?                  @default(0)
  is_on_sale          Boolean?              @default(false)
  discount_start      String?               @db.VarChar(10)
  discount_end        String?               @db.VarChar(10)
  
  customer_favourites customer_favourites[]
  order_items         order_items[]
  categories          categories            @relation(fields: [category_slug], references: [slug], map: "products_ibfk_1")

  @@index([category_slug], map: "category_slug")
}

model transactions {
  id               String                @id @default(uuid()) @db.VarChar(50)
  reference_id     String?               @db.VarChar(50)
  type             transactions_type
  category         transactions_category
  amount           Int
  description      String?               @db.Text
  transaction_date DateTime              @db.Date
  created_at       DateTime              @default(now()) @db.Timestamp(0)
}

model users {
  id            String        @id @default(uuid()) @db.VarChar(50)
  name          String        @db.VarChar(255)
  email         String        @unique(map: "email") @db.VarChar(255)
  password_hash String        @db.VarChar(255)
  role          users_role?   @default(admin)
  status        users_status? @default(ACTIVE)
  last_login    DateTime?     @db.DateTime(0)
  created_at    DateTime      @default(now()) @db.Timestamp(0)
}

model customers {
  id               String   @id @default(uuid())
  name             String
  email            String   @unique
  password         String
  phone            String?
  profile_image    String?
  status           String   @default("ACTIVE")
  created_at       DateTime @default(now())
  last_login       DateTime?

  // Add this ONE line right here! 👇
  addresses        customer_addresses[] 
  
  // (You probably also have your favourites relation here too)
  favourites       customer_favourites[]
}

model customer_favourites {
  id          String    @id @default(uuid()) @db.VarChar(50)
  customer_id String    @db.VarChar(50)
  product_id  String    @db.VarChar(50)
  created_at  DateTime  @default(now()) @db.Timestamp(0)
  customers   customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "customer_favourites_ibfk_1")
  products    products  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "customer_favourites_ibfk_2")

  @@unique([customer_id, product_id], map: "unique_fav")
  @@index([product_id], map: "product_id")
}

model customer_addresses {
  id          String   @id @default(uuid())
  customer_id String
  label       String
  full_name   String
  phone       String
  street      String
  city        String
  postal_code String
  is_default  Boolean  @default(false)

  // Relation back to the customer
  customer    customers @relation(fields: [customer_id], references: [id], onDelete: Cascade)
}

// NOTE: Add this single line inside your existing "model customers" block:
// addresses customer_addresses[]

enum transactions_type {
  CREDIT
  DEBIT
}

enum transactions_category {
  SALES
  PROCUREMENT
  OPERATIONAL
  SHIPPING
}

enum orders_status {
  PENDING_PROCESSING
  SHIPPED
  CANCELLED
}

enum users_role {
  admin
  manager
}

enum users_status {
  ACTIVE
  SUSPENDED
}
